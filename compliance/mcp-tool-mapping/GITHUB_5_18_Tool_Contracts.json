{
  "control_code": "5.18",
  "control_name": "Access rights",
  "provider": "github",
  "required_tools": [
    "list_collaborators",
    "get_repository"
  ],
  "optional_tools": [
    "list_teams",
    "get_team_members"
  ],
  "contracts": [
    {
      "name": "list_collaborators",
      "title": "List Repository Collaborators",
      "description": "List repository collaborators and their permission levels for least-privilege evaluation.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "affiliation": {
            "type": "string",
            "description": "Collaborator affiliation filter.",
            "enum": [
              "outside",
              "direct",
              "all"
            ],
            "default": "all"
          },
          "per_page": {
            "type": "number",
            "description": "Results per page (1-100).",
            "minimum": 1,
            "maximum": 100,
            "default": 100
          },
          "page": {
            "type": "number",
            "description": "Pagination page number (min 1).",
            "minimum": 1,
            "default": 1
          }
        },
        "required": [
          "owner",
          "repo"
        ],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "login": {
                  "type": "string"
                },
                "id": {
                  "type": "number"
                },
                "type": {
                  "type": "string"
                },
                "role_name": {
                  "type": "string"
                },
                "permissions": {
                  "type": "object",
                  "properties": {
                    "admin": {
                      "type": "boolean"
                    },
                    "maintain": {
                      "type": "boolean"
                    },
                    "push": {
                      "type": "boolean"
                    },
                    "triage": {
                      "type": "boolean"
                    },
                    "pull": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": true
                },
                "outside_collaborator": {
                  "type": "boolean"
                }
              },
              "required": [
                "login",
                "permissions"
              ],
              "additionalProperties": true
            }
          },
          "total_count": {
            "type": "number"
          }
        },
        "required": [
          "items"
        ],
        "additionalProperties": true
      },
      "github_rest": {
        "method": "GET",
        "path": "/repos/{owner}/{repo}/collaborators",
        "query": {
          "affiliation": "all",
          "per_page": 100,
          "page": 1
        }
      }
    },
    {
      "name": "get_repository",
      "title": "Get Repository Metadata",
      "description": "Get repository metadata including visibility and ownership details.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          }
        },
        "required": [
          "owner",
          "repo"
        ],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "full_name": {
            "type": "string"
          },
          "private": {
            "type": "boolean"
          },
          "visibility": {
            "type": "string"
          },
          "default_branch": {
            "type": "string"
          },
          "owner": {
            "type": "object",
            "properties": {
              "login": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            },
            "required": [
              "login"
            ],
            "additionalProperties": true
          }
        },
        "required": [
          "full_name",
          "private"
        ],
        "additionalProperties": true
      },
      "github_rest": {
        "method": "GET",
        "path": "/repos/{owner}/{repo}"
      }
    }
  ],
  "implementation_notes": [
    "Expose both tools in tools/list. If either tool is missing, control 5.18 must remain UNDETERMINED.",
    "When returning structuredContent, also include equivalent JSON in a text content block for backward compatibility.",
    "Set isError=true for runtime validation/business errors (for example: missing owner or repo, permission denied, upstream API failure).",
    "Tool names must match exactly: list_collaborators and get_repository."
  ]
}
