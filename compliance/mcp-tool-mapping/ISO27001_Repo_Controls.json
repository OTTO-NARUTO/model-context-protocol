{
  "compliance_standard": "ISO 27001:2022",
  "controls": [
    {
      "control_code": "8.9",
      "control_name": "Configuration management",
      "component": "Technological controls",
      "mappings": [
        {
          "evidence_source": "code_repo_scan",
          "tools": {
            "github": [
              "get_branch_protection",
              "get_repository"
            ],
            "gitlab": [
              "get_project_protected_branches"
            ],
            "bitbucket": [
              "list_branch_restrictions"
            ]
          },
          "logic": {
            "requirementType": "all_must_be_true",
            "conditions": [
              {
                "field": "branch_protection_enabled",
                "operator": "equals",
                "value": true
              },
              {
                "field": "force_push_blocked",
                "operator": "equals",
                "value": true
              }
            ],
            "description": "Primary branches must be protected and force push must be blocked"
          }
        }
      ]
    },
    {
      "control_code": "8.28",
      "control_name": "Secure coding",
      "component": "Technological controls",
      "mappings": [
        {
          "evidence_source": "code_review_scan",
          "tools": {
            "github": "list_pull_requests",
            "gitlab": "list_merge_requests",
            "bitbucket": "list_pullrequests"
          },
          "logic": {
            "requirementType": "min_reviews",
            "field": "approved_reviews_count",
            "threshold": 1,
            "description": "All merged pull/merge requests must have at least one approved review"
          }
        }
      ]
    }
  ]
}
