{
  "compliance_standard": "ISO 27001:2022",
  "controls": [
    {
      "control_code": "5.18",
      "control_name": "Access rights",
      "component": "Organizational controls",
      "mappings": [
        {
          "evidence_source": "identity_scan",
          "tools": {
            "github": "list_collaborators",
            "gitlab": "list_project_members",
            "bitbucket": "bb_ls_users"
          },
          "logic": {
            "requirementType": "max_count",
            "field": "admin_users",
            "threshold": 2,
            "description": "Number of users with administrative privileges must not exceed allowed threshold"
          }
        }
      ]
    },
    {
      "control_code": "8.8",
      "control_name": "Management of technical vulnerabilities",
      "component": "Technological controls",
      "mappings": [
        {
          "evidence_source": "vapt_scan",
          "tools": {
            "github": "list_code_scanning_alerts",
            "gitlab": "list_vulnerability_findings",
            "bitbucket": "bb_list_vulnerabilities"
          },
          "logic": {
            "requirementType": "none_allowed",
            "field": "open_high_severity_alerts",
            "description": "No open high severity vulnerabilities should exist"
          }
        }
      ]
    },
    {
      "control_code": "8.9",
      "control_name": "Configuration management",
      "component": "Technological controls",
      "mappings": [
        {
          "evidence_source": "code_repo_scan",
          "tools": {
            "github": "get_branch_protection",
            "gitlab": "get_project_protected_branches",
            "bitbucket": "list_branch_restrictions"
          },
          "logic": {
            "requirementType": "all_must_be_true",
            "field": "branch_protection_enabled",
            "description": "All primary branches must have protection rules enabled"
          }
        }
      ]
    },
    {
      "control_code": "8.28",
      "control_name": "Secure coding",
      "component": "Technological controls",
      "mappings": [
        {
          "evidence_source": "code_review_scan",
          "tools": {
            "github": {
              "listMerged": "search_pull_requests",
              "readReviews": "pull_request_read"
            },
            "gitlab": {
              "listMerged": "list_merge_requests",
              "readApprovals": "get_merge_request_approvals"
            },
            "bitbucket": {
              "listMerged": "list_pullrequests",
              "readApprovals": "get_pullrequest_approvals"
            }
          },
          "logic": {
            "requirementType": "min_reviews",
            "field": "approved_reviews_count",
            "threshold": 1,
            "description": "All merged pull/merge requests must have at least one approved review"
          }
        }
      ]
    },
    {
      "control_code": "8.29",
      "control_name": "Security testing in development",
      "component": "Technological controls",
      "mappings": [
        {
          "evidence_source": "pipeline_security_scan",
          "tools": {
            "github": "list_check_runs",
            "gitlab": "list_pipeline_jobs",
            "bitbucket": "bb_list_pipelines"
          },
          "logic": {
            "requirementType": "no_failures",
            "field": "failed_security_checks",
            "description": "No security-related CI/CD checks should be failing"
          }
        }
      ]
    }
  ]
}