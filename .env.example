PORT=8080
NODE_ENV=development
FRONTEND_BASE_URL=http://localhost:8080
ENCRYPTION_KEY=replace_with_a_32_plus_char_secret
TENANT_SESSION_SECRET=replace_with_a_32_plus_char_session_secret
TENANT_SESSION_TTL_MINUTES=480

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback
GITHUB_MCP_URL=https://your-github-mcp-server
GITHUB_API_BASE_URL=https://api.github.com

GITLAB_CLIENT_ID=your_gitlab_client_id
GITLAB_CLIENT_SECRET=your_gitlab_client_secret
GITLAB_REDIRECT_URI=http://localhost:8080/api/auth/gitlab/callback
GITLAB_MCP_URL=https://your-gitlab-mcp-server
GITLAB_API_BASE_URL=https://gitlab.com/api/v4

BITBUCKET_CLIENT_ID=your_bitbucket_client_id
BITBUCKET_CLIENT_SECRET=your_bitbucket_client_secret
BITBUCKET_REDIRECT_URI=http://localhost:8080/api/auth/bitbucket/callback
BITBUCKET_MCP_URL=https://your-bitbucket-mcp-server
BITBUCKET_API_BASE_URL=https://api.bitbucket.org/2.0

REST_TOOL_CONTRACTS_PATH=config/rest-tool-contracts.json
PROVIDER_TOOL_SUPPORT_PATH=config/provider-tool-support.json
